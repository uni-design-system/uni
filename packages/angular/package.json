{
  "name": "@uni-design-system/uni-angular",
  "version": "3.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/uni-design-system/uni",
    "directory": "packages/angular"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "directory": "dist"
  },
  "private": false,
  "scripts": {
    "build": "pnpm ng-packagr -p ng-package.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "storybook": "pnpm ng run @uni-design-system/uni-angular:storybook",
    "build-storybook": "pnpm architect @uni-design-system/uni-angular:build-storybook",
    "release": "pnpm build && pnpm changeset publish"
  },
  "peerDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@emotion/css": "^11.0.0",
    "@uni-design-system/uni-core": "workspace:*"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^2.5.1",
    "@analogjs/vite-plugin-angular": "^2.5.0",
    "@angular-devkit/architect": "^0.2102.10",
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular-devkit/core": "21.2.10",
    "@angular/compiler": "21.2.12",
    "@angular/compiler-cli": "21.2.12",
    "@angular/forms": "21.2.12",
    "@angular/platform-browser-dynamic": "21.2.12",
    "@emotion/css": "^11.0.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/angular": "^10.4.0",
    "@storybook/builder-vite": "^10.4.0",
    "@types/react": "^18.3.28",
    "@uni-design-system/tsconfig": "workspace:*",
    "angular-eslint": "^22.1.0",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "ng-packagr": "^21.0.0",
    "react": "^18.2.0",
    "storybook": "^10.4.0",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6"
  }
}
