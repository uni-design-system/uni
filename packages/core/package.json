{
  "name": "@uni-design-system/uni-core",
  "version": "1.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/uni-design-system/uni",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "private": false,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./theme": {
      "types": "./dist/types/theme/index.d.ts",
      "import": "./dist/esm/theme/index.js",
      "require": "./dist/cjs/theme/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && pnpm build:types && pnpm build:esm && pnpm build:cjs",
    "build:types": "tsc --project tsconfig.types.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json && node -e \"const fs=require('node:fs');fs.mkdirSync('dist/cjs',{recursive:true});fs.writeFileSync('dist/cjs/package.json','{\\\"type\\\":\\\"commonjs\\\"}\\n');\"",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@uni-design-system/tsconfig": "workspace:*",
    "typescript": "^5.0.0"
  }
}
