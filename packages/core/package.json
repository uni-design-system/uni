{
  "name": "@uni-design-system/uni-core",
  "version": "1.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/uni-design-system/uni",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "private": false,
  "sideEffects": false,
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./theme": {
      "types": "./dist/types/theme/index.d.ts",
      "import": "./dist/esm/theme/index.js",
      "require": "./dist/cjs/theme/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && pnpm build:types && pnpm build:esm && pnpm build:cjs",
    "build:types": "tsc --project tsconfig.types.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json && find dist/cjs -type f -name '*.js' -exec sh -c 'mv \"$1\" \"${1%.js}.cjs\"' _ {} \\;"
  },
  "devDependencies": {
    "@uni-design-system/tsconfig": "workspace:*",
    "typescript": "^5.0.0"
  }
}
