{
  "name": "uni",
  "packageManager": "pnpm@11.0.8",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run storybook",
    "dev:hub": "turbo run storybook --filter=@uni-design-system/uni-docs --filter=@uni-design-system/uni-react --filter=@uni-design-system/uni-angular",
    "format": "prettier --write .",
    "lint": "turbo lint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@storybook/react-vite": "^10.4.0",
    "@types/node": "^25.6.0",
    "csstype": "^3.2.3",
    "prettier": "^3.8.3",
    "storybook": "^10.4.0",
    "turbo": "^2.9.8",
    "typescript": "~5.9.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@angular/common": "21.2.12",
    "@angular/compiler": "21.2.12",
    "@angular/core": "21.2.12"
  },
  "pnpm": {
    "overrides": {
      "storybook": "10.3.6",
      "@storybook/angular": "10.3.6",
      "@storybook/addon-essentials": "10.3.6",
      "@storybook/addon-links": "10.3.6",
      "@storybook/addon-interactions": "10.3.6",
      "@storybook/addon-docs": "10.3.6",
      "@storybook/addon-a11y": "10.3.6",
      "@storybook/addon-toolbars": "10.3.6",
      "@storybook/blocks": "10.3.6",
      "@storybook/manager-api": "10.3.6",
      "@storybook/preview-api": "10.3.6",
      "@storybook/types": "10.3.6"
    }
  }
}
