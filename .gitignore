# --- Yarn Zero-Installs ---
# First, ignore everything in .yarn
.yarn/*

# Then, explicitly UN-ignore the things needed for Zero-Installs
!.yarn/cache
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Always ignore these specific Yarn artifacts
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# --- Turborepo & Build Outputs ---
.turbo
node_modules
dist
.next
out

# --- Environment & Logs ---
.env*
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- System Files ---
.DS_Store
Thumbs.db

# --- IDEs ---
/.idea/

*storybook.log
storybook-static
